{
    "include": [
        "."
    ],
    "exclude": [
        "__pycache__",
        "migrations",
        "stubs"
    ],
    "reportMissingImports": "none",
    "reportMissingModuleSource": "none",
    "reportMissingTypeStubs": "none",
    "pythonVersion": "3.12",
    "pythonPlatform": "Windows",
    "typeCheckingMode": "off",
    "useLibraryCodeForTypes": true,
    "venvPath": ".",
    "venv": "venv"
}
